# Copy this file to .env on the server and fill in real values.
# NEVER commit the real .env file to GitHub.

# PostgreSQL connection
DB_HOST=localhost
DB_NAME=autorion
DB_USER=autorion_user
DB_PASSWORD=changeme

# Default admin account (created automatically on first startup if both
# values below are set). Leave ADMIN_PASSWORD empty to skip auto-creation.
ADMIN_EMAIL=admin@autorion.net
ADMIN_PASSWORD=changeme

# Ecomail transactional email integration (not yet wired up in code —
# placeholder for when the transactional tier is activated).
# FROM must be on the verified transactional domain (info.autorion.net).
# REPLY_TO can be any mailbox — no domain verification needed for it,
# since replies go straight to your own mail server (Outlook), not Ecomail.
ECOMAIL_API_KEY=changeme
ECOMAIL_FROM_EMAIL=event@info.autorion.net
ECOMAIL_REPLY_TO=marketing@autorion.cz

# Encryption key for guest consent signatures (handwritten signature images
# from the check-in app). Without this key, signature storage is disabled
# (registration/check-in still works fine — only signature capture is skipped).
# Generate one on the server with:
#   /opt/autorion/venv/bin/python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this secret and BACK IT UP — if it's lost, previously stored
# signatures become permanently unreadable (this is intentional: nobody
# without the key, including us, can read them).
SIGNATURE_ENCRYPTION_KEY=changeme
